# =============================================================================
# MedSwin - Medical RAG System with Multi-Agent Conversation
# =============================================================================
# Copy this file to .env and update the values

# -----------------------------------------------------------------------------
# Core Application Settings
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8100
APP_NAME=MedSwin
DEBUG=false
VERSION=1.0.0

# CORS settings
ALLOWED_ORIGINS=["*"]

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=medswin

# -----------------------------------------------------------------------------
# Model Endpoints (OpenAI-compatible assumed)
# -----------------------------------------------------------------------------
# Supervisor model endpoint (port 8000)
SUPERVISOR_URL=http://localhost:8000/v1/chat/completions

# Specialist agent endpoints (ports 8001-8003)
AGENT1_URL=http://localhost:8001/v1/chat/completions
AGENT2_URL=http://localhost:8002/v1/chat/completions
AGENT3_URL=http://localhost:8003/v1/chat/completions

# Reranker endpoint (port 8004)
RERANKER_URL=http://localhost:8004/rerank

# Embedding endpoint (port 8005)
EMBEDDING_URL=http://localhost:8005/embeddings

# -----------------------------------------------------------------------------
# Service Timeouts (seconds)
# -----------------------------------------------------------------------------
LLM_TIMEOUT_S=60
RERANK_TIMEOUT_S=30
EMBED_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Retrieval Configuration
# -----------------------------------------------------------------------------
DEFAULT_TOP_K=5
CANDIDATE_K=80
CANDIDATE_K_PRIME=120
MAX_RETRIEVE_LOOPS=3
TOKEN_BUDGET_B=1800
ENABLE_BM25=true
DEFAULT_INDEX_TYPE=hnsw
INDEX_STRATEGY_MODE=dynamic

# Legacy retrieval settings (for backward compatibility)
MAX_TOP_K=20
RERANK_TOP_K=10
FINAL_TOP_K=3

# -----------------------------------------------------------------------------
# Evidence Sufficiency Policy
# -----------------------------------------------------------------------------
SUFF_T_CPG=2
SUFF_T_EMR=2
SUFF_T_INCLUSION=0.55
SUFF_T_MEAN_CONF=0.60

# -----------------------------------------------------------------------------
# Fusion Score Weights (must sum to 1.0)
# -----------------------------------------------------------------------------
W_RERANK=0.45
W_DENSE=0.25
W_LEX=0.10
W_RECENCY=0.07
W_SECTION=0.08
W_SOURCE=0.05

# -----------------------------------------------------------------------------
# MMR (Maximal Marginal Relevance) Configuration
# -----------------------------------------------------------------------------
MMR_LAMBDA=0.75
MMR_MAX_EVIDENCE_CHUNKS=10

# -----------------------------------------------------------------------------
# Enterprise Features (Feature Flags)
# -----------------------------------------------------------------------------
ENABLE_AUTH=false
ENABLE_RBAC=false
ENABLE_OTEL=false
LOG_REDACT_PHI=true

# -----------------------------------------------------------------------------
# Legacy Model Settings (for backward compatibility)
# -----------------------------------------------------------------------------
# Embedding model path (if using local models instead of endpoint)
EMBEDDING_MODEL_PATH=/app/models/MedEmbed-large-v0.1
EMBEDDING_DIMENSION=768
MAX_SEQUENCE_LENGTH=512

# Reranker model path (if using local models instead of endpoint)
RERANKER_MODEL_PATH=/app/models/bge-reranker-v2-m3

# -----------------------------------------------------------------------------
# Storage Settings
# -----------------------------------------------------------------------------
HNSW_INDEX_PATH=/app/data/hnsw_index.bin
HNSW_MAPPING_PATH=/app/data/hnsw_mapping.json
FAISS_INDEX_PATH=/app/data/faiss_index.bin
FAISS_MAPPING_PATH=/app/data/faiss_mapping.json
TREE_INDEX_PATH=/app/data/tree_index.npy
TREE_MAPPING_PATH=/app/data/tree_mapping.json
DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# Chunking Settings
# -----------------------------------------------------------------------------
TARGET_CHUNK_SIZE=400
BATCH_SIZE=64

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=[".csv", ".json", ".txt", ".pdf"]

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# -----------------------------------------------------------------------------
# Hugging Face Settings
# -----------------------------------------------------------------------------
HF_TOKEN=your_huggingface_token_here

# -----------------------------------------------------------------------------
# AWS Settings (for EC2 deployment)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
EC2_INSTANCE_TYPE=g4dn.xlarge
