# Environment Configuration for RAG System
# Copy this file to .env and update the values

# Application settings
APP_NAME=Medical RAG System
DEBUG=false
VERSION=1.0.0

# Server settings
HOST=0.0.0.0
PORT=8000

# CORS settings
ALLOWED_ORIGINS=["*"]

# Database settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=medical_rag_db

# Model settings
EMBEDDING_MODEL_PATH=/app/models/MedEmbed-large-v0.1
RERANKER_MODEL_PATH=/app/models/bge-reranker-v2-m3
EMBEDDING_DIMENSION=768
MAX_SEQUENCE_LENGTH=512

# Storage settings
HNSW_INDEX_PATH=/app/data/hnsw_index.bin
HNSW_MAPPING_PATH=/app/data/hnsw_mapping.json
DATA_DIR=/app/data

# Retrieval settings
DEFAULT_TOP_K=5
MAX_TOP_K=20
RERANK_TOP_K=10
FINAL_TOP_K=3

# Chunking settings
TARGET_CHUNK_SIZE=400
BATCH_SIZE=64

# File upload settings
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=[".csv", ".json", ".txt"]

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# AWS settings (for EC2 deployment)
AWS_REGION=us-east-1
EC2_INSTANCE_TYPE=g4dn.xlarge

# Hugging Face settings
HF_TOKEN=your_huggingface_token_here
